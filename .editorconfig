# .editorconfig with ALL CsLint rules enabled

root = true

[*.cs]

########################################
# Tier 1 — Text-level formatting
########################################

# CSLINT001: TrailingWhitespace
trim_trailing_whitespace = true

# CSLINT002: Indentation
indent_style = space
indent_size = 4

# CSLINT003: LineEnding
# end_of_line = lf

# CSLINT004: FinalNewline
insert_final_newline = true

# CSLINT005: MaxLineLength
max_line_length = 150

# CSLINT006: NoRegionDirectives
csharp_no_region_directives = true

# CSLINT007: FileHeader (set to "unset" to require no header, or provide a template)
file_header_template = unset

# CSLINT008: MultipleBlankLines
csharp_no_multiple_blank_lines = true

# CSLINT009: NoBlankLinesAtStartOfFile
csharp_no_blank_lines_at_start_of_file = true

# CSLINT010: Utf8FileEncoding
csharp_store_files_as_utf8 = true

########################################
# Tier 2 — Naming conventions
########################################

# CSLINT100: TypeNaming — PascalCase for types
dotnet_naming_rule.types_should_be_pascal_case = true:warning

# CSLINT101: InterfacePrefix — interfaces must start with 'I'
dotnet_naming_rule.interface_should_begin_with_i = true:warning

# CSLINT102: MemberNaming — PascalCase for members
dotnet_naming_rule.members_should_be_pascal_case = true:warning

# CSLINT103: ParameterLocalNaming — camelCase for parameters/locals
dotnet_naming_rule.locals_should_be_camel_case = true:warning

# CSLINT104: FieldNaming — _camelCase for private fields
dotnet_naming_rule.private_fields_should_be_underscore_camel_case = true:warning

# CSLINT105: ConstantNaming — PascalCase for constants
dotnet_naming_rule.constants_should_be_pascal_case = true:warning

# CSLINT106: TypeParameterNaming — must begin with 'T'
dotnet_naming_rule.type_parameters_should_begin_with_t = true:warning

########################################
# Tier 3 — Style preferences
########################################

# CSLINT200: VarPreference
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = false:warning

# CSLINT201: ExpressionBodied
csharp_style_expression_bodied_methods = when_on_single_line:warning
csharp_style_expression_bodied_properties = true:warning
csharp_style_expression_bodied_accessors = true:warning

# CSLINT202: BracePreference
csharp_prefer_braces = true:warning

# CSLINT203: NamespaceDeclaration
csharp_style_namespace_declarations = file_scoped:warning

# CSLINT204: ThisQualification
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# CSLINT205: ModifierOrder
csharp_preferred_modifier_order = public, private, protected, internal, file, static, extern, new, virtual, abstract, sealed, override, readonly, unsafe, required, volatile, async:warning

# CSLINT206: AccessibilityModifier
dotnet_style_require_accessibility_modifiers = always:warning

# CSLINT207: UsingDirectivePlacement
csharp_using_directive_placement = outside_namespace:warning

# CSLINT208: PredefinedType
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# CSLINT209: PatternMatching
csharp_style_pattern_matching_over_is_with_cast_check = true:warning

# CSLINT210: NullChecking
dotnet_style_null_checking = true:warning

# CSLINT211: UsingDeclaration
csharp_prefer_simple_using_statement = true:warning

# CSLINT212: TargetTypedNew
csharp_style_implicit_object_creation_when_type_is_apparent = true:warning

# CSLINT213: SimpleDefaultExpression
csharp_prefer_simple_default_expression = true:warning

# CSLINT214: CompoundAssignment
dotnet_style_prefer_compound_assignment = true:warning

# CSLINT215: ObjectInitializer
dotnet_style_object_initializer = true:warning

# CSLINT216: CollectionInitializer
dotnet_style_collection_initializer = true:warning

# CSLINT217: ExpressionBodiedLambdas
csharp_style_expression_bodied_lambdas = true:warning

# CSLINT218: ExpressionBodiedLocalFunctions
csharp_style_expression_bodied_local_functions = when_on_single_line:warning

# CSLINT219: PatternMatchingNot
csharp_style_prefer_not_pattern = true:warning

# CSLINT220: PatternMatchingCombinator
csharp_style_prefer_pattern_matching = true:warning

# CSLINT221: PrimaryConstructor
csharp_style_prefer_primary_constructors = true:warning

# CSLINT222: CollectionExpression
dotnet_style_prefer_collection_expression = true:warning

# CSLINT223: TupleSwap
csharp_style_prefer_tuple_swap = true:warning

# CSLINT224: Utf8StringLiteral
csharp_style_prefer_utf8_string_literals = true:warning

# CSLINT225: SimplifyInterpolation
dotnet_style_prefer_simplified_interpolation = true:warning

# CSLINT226: IndexOperator
csharp_style_prefer_index_operator = true:warning

# CSLINT227: RangeOperator
csharp_style_prefer_range_operator = true:warning

# CSLINT228: EmbeddedStatement
csharp_style_allow_embedded_statements_on_same_line = false:warning

# CSLINT229: ConsecutiveBraces
csharp_style_allow_blank_lines_between_consecutive_braces = false:warning

# CSLINT230: BlankLineAfterBlock
csharp_style_allow_blank_line_after_block = false:warning

# CSLINT231: ConstructorInitializerBlankLine
csharp_style_allow_blank_line_after_colon_in_constructor_initializer = false:warning

# CSLINT232: ConditionalExpressionBlankLine
csharp_style_allow_blank_line_after_token_in_conditional_expression = false:warning

# CSLINT233: ArrowExpressionBlankLine
csharp_style_allow_blank_line_after_token_in_arrow_expression_clause = false:warning

# CSLINT234: InferredMemberName
dotnet_style_prefer_inferred_anonymous_type_member_names = true:warning

# CSLINT235: SimplifiedBooleanExpression
dotnet_style_prefer_simplified_boolean_expressions = true:warning

# CSLINT236: ExtendedPropertyPattern
csharp_style_prefer_extended_property_pattern = true:warning

# CSLINT237: EmptyFinalizer
csharp_no_empty_finalizers = true:warning

# CSLINT238: UnnecessaryInitialization
csharp_no_unnecessary_initialization = true:warning

# CSLINT239: SealedTypePreference
csharp_prefer_sealed_types = true:warning

# CSLINT240: NoEmptyStatements
csharp_no_empty_statements = true:warning

# CSLINT241: SingleStatementPerLine
csharp_single_statement_per_line = true:warning

# CSLINT242: NoYodaConditions
csharp_no_yoda_conditions = true:warning

# CSLINT243: NoCombinedFieldDeclarations
csharp_no_combined_field_declarations = true:warning

# CSLINT244: NoCombinedAttributes
csharp_no_combined_attributes = true:warning

# CSLINT245: AttributesOnOwnLine
csharp_attributes_on_own_line = true:warning

# CSLINT246: EnumValuesOnSeparateLines
csharp_enum_values_on_separate_lines = true:warning

# CSLINT247: NoBlankLineAfterOpeningBrace
csharp_no_blank_line_after_opening_brace = true:warning

# CSLINT248: NoBlankLineBeforeClosingBrace
csharp_no_blank_line_before_closing_brace = true:warning

# CSLINT249: NoBlankLineBeforeOpeningBrace
csharp_no_blank_line_before_opening_brace = true:warning

# CSLINT250: ElementsSeparatedByBlankLine
# csharp_elements_separated_by_blank_line = true:warning

# CSLINT251: FieldsMustBePrivate
csharp_fields_must_be_private = true:warning

# CSLINT252: SingleTypePerFile
csharp_single_type_per_file = true:warning

# CSLINT253: TrailingCommas
csharp_trailing_commas_in_multi_line_initializers = true:warning

# CSLINT254: KeywordSpacing
csharp_keyword_spacing = true:warning

# CSLINT255: CommaSpacing
csharp_comma_spacing = true:warning

# CSLINT256: SemicolonSpacing
csharp_semicolon_spacing = true:warning

# CSLINT257: OperatorSpacing
csharp_operator_spacing = true:warning

# CSLINT258: CommentSpacing
csharp_comment_spacing = true:warning

# CSLINT259: ParenthesisSpacing
csharp_parenthesis_spacing = true:warning

# CSLINT260: BraceSpacing
csharp_brace_spacing = true:warning

# CSLINT261: ColonSpacing
csharp_colon_spacing = true:warning

# CSLINT262: NoMultipleWhitespace
csharp_no_multiple_whitespace = true:warning

# CSLINT263: AccessorOrdering
csharp_accessor_ordering = true:warning

# CSLINT264: ReadonlyFieldOrder
csharp_readonly_before_mutable = true:warning

# CSLINT265: ConstantFieldOrder
csharp_constants_before_fields = true:warning

# CSLINT266: StaticMemberOrder
csharp_static_before_instance = true:warning

# CSLINT267: ElementAccessOrder
csharp_element_access_ordering = true:warning

# CSLINT268: ElementOrder
csharp_element_ordering = true:warning

# CSLINT269: UsingDirectiveOrder
csharp_using_directive_ordering = true:warning

# CSLINT305: EmptyCatchBlock
csharp_no_empty_catch_blocks = true:warning

########################################
# Tier 4 — Semantic analysis (--semantic)
########################################

# CSLINT300: UnusedUsings
dotnet_diagnostic.CSLINT300.severity = warning

# CSLINT301: UnusedLocalVariable
dotnet_diagnostic.CSLINT301.severity = warning

# CSLINT302: UnreachableCode
dotnet_diagnostic.CSLINT302.severity = warning

# CSLINT303: DuplicateEnumValue
dotnet_diagnostic.CSLINT303.severity = warning

# CSLINT304: SelfAssignment
dotnet_diagnostic.CSLINT304.severity = warning

# CSLINT306: UnnecessaryCast
dotnet_diagnostic.CSLINT306.severity = warning

# CSLINT307: RedundantAwait
dotnet_diagnostic.CSLINT307.severity = warning

# CSLINT308: UnusedPrivateMember
dotnet_diagnostic.CSLINT308.severity = warning
